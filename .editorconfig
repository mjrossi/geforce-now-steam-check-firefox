# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{ts,js,mjs,json,jsonc,yaml,yml,css,html,md}]
indent_style = space
indent_size = 2

# justfile recipes use 4-space indentation (avoids the Makefile tab gotcha).
[justfile]
indent_style = space
indent_size = 4
